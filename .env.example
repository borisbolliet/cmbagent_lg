# Copy to .env and fill in.

# --- Models -------------------------------------------------------------
GOOGLE_API_KEY=

# Required only for the self_debug *escalation* node (PlanContext.enable_escalation).
# Escalation runs a Claude Agent SDK agent — the one Anthropic dependency.
ANTHROPIC_API_KEY=

# --- Langfuse (self-hosted via ~/GitHub/langfuse docker compose) --------
# After `docker compose up -d` in ~/GitHub/langfuse, create a project in
# http://localhost:3000 and paste its keys here.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
